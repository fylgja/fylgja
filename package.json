{
  "name": "fylgja",
  "version": "2.2.1",
  "description": "The modular CSS library. Powered via CSS components",
  "homepage": "https://fylgja.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/fylgja/fylgja"
  },
  "bugs": "https://github.com/fylgja/fylgja/issues",
  "author": "Fylgja",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": [
    "fylgja",
    "css",
    "scss",
    "framework",
    "library",
    "metapackage"
  ],
  "bin": {
    "fylgja": "./bin/fylgja.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "test": "npx stylelint **/*.scss"
  },
  "dependencies": {
    "@fylgja/base": "^2.1.6",
    "@fylgja/tokens": "^2.2.1",
    "@fylgja/utilities": "^2.1.3"
  },
  "devDependencies": {
    "@fylgja/stylelint-config": "^8.0.1",
    "lightningcss-cli": "^1.32.0",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "typescript": "^6.0.3"
  },
  "stylelint": {
    "extends": "@fylgja/stylelint-config",
    "rules": {
      "scss/load-partial-extension": null,
      "scss/operator-no-unspaced": null
    },
    "ignoreFiles": [
      "**/_experiments/**/*"
    ]
  }
}
